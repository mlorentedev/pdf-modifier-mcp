# =============================================================================
# .env.example — environment variables for Docker deployment
# Copy to .env and fill in real values. Never commit .env.
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_NAME=pdf-modifier-mcp
APP_ENV=production
DEBUG=false

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000

# ---------------------------------------------------------------------------
# CORS (comma-separated origins)
# ---------------------------------------------------------------------------
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ---------------------------------------------------------------------------
# NaN Cloud API (AI features)
# ---------------------------------------------------------------------------
NAN_API_KEY=your_nan_api_key_here
NAN_API_BASE=https://api.nan.builders/v1

# ---------------------------------------------------------------------------
# PDF Storage
# ---------------------------------------------------------------------------
STORAGE_PATH=/app/storage
MAX_UPLOAD_SIZE=50MB

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------
# Generate a new key: python -c "import secrets; print(secrets.token_urlsafe(32))"
# → Paste output here. Required for session signing.
SECRET_KEY=
